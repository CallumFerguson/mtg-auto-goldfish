{
  "name": "mtg-auto-deck",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:client": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit && vite build",
    "deploy": "npm run build:client && wrangler deploy",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "ngrok": "ngrok http 3001 --host-header=rewrite",
    "server:build": "tsc -p tsconfig.server.json",
    "server:dev": "tsx mtg-auto-deck-server/mtg-auto-deck-server.ts",
    "server:watch": "tsx watch --include \"mtg-auto-deck-server/**/*.ts\" mtg-auto-deck-server/mtg-auto-deck-server.ts",
    "server:start": "node dist-server/mtg-auto-deck-server.js",
    "test:openrouter-agent": "node tests/openrouter-agent-square-root.mjs",
    "test": "npm run server:build && node dist-server/llm-run-events.test.js && node dist-server/llamacpp-chat.test.js && node dist-server/simulation-results-stream.test.js && node dist-server/starter-decks-postgres.test.js && tsc -p tsconfig.stream-test.json && node node_modules/.tmp/stream-test/tests/simulation-results-stream.test.js",
    "typecheck": "tsc -b --noEmit",
    "preview": "vite preview",
    "preview:cloudflare": "npm run build:client && wrangler dev"
  },
  "dependencies": {
    "@better-auth/stripe": "^1.6.11",
    "@fontsource-variable/inter": "^5.2.8",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openrouter/agent": "^0.4.0",
    "@tailwindcss/vite": "^4.2.1",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "lucide-react": "^0.577.0",
    "mana-font": "^1.18.0",
    "nodemailer": "^8.0.7",
    "openai": "^6.34.0",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.0",
    "shadcn": "^4.1.0",
    "stripe": "^22.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "wrangler": "^4.91.0"
  }
}
