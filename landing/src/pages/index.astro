---
const appBaseUrl = "https://app.mtgautodeck.com"
const signUpUrl = `${appBaseUrl}/sign-up`
const signInUrl = `${appBaseUrl}/sign-in`

const features = [
  {
    label: "Automated goldfishing",
    description:
      "Let an AI play through your deck and surface the real problems with your deck.",
  },
  {
    label: "Faster deck iteration",
    description:
      "Run dozens of simulations in the time it would take you to goldfish your deck a few times.",
  },
  {
    label: "Simulation depth",
    description: "Uncover problems you didn't know your deck has.",
  },
]

const plans = [
  {
    name: "Free",
    price: "$0",
    cadence: "/mo",
    description: "A simple way to try AI-driven goldfishing.",
    features: [
      "Limited access to basic simulations",
      "Run 1 simulation at a time",
    ],
    cta: "Try it for free",
  },
  {
    name: "Plus",
    price: "$4.99",
    cadence: "/mo",
    description: "More room to test and iterate.",
    features: [
      "Access to more intelligent simulations",
      "Run up to 2 simulations at a time",
    ],
    cta: "Start with Plus",
  },
  {
    name: "Pro",
    price: "$9.99",
    cadence: "/mo",
    description: "Test and iterate faster.",
    features: [
      "Access to the most intelligent simulations",
      "Higher usage limits",
      "Run up to 5 simulations at a time",
    ],
    cta: "Start with Pro",
  },
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="MTG Auto Deck is an AI goldfishing tool that automatically plays your Magic deck so you can test faster."
    />
    <meta name="theme-color" content="#0b1020" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <title>MTG Auto Deck | AI Goldfishing for Magic Decks</title>
  </head>
  <body>
    <header class="site-header" aria-label="Main navigation">
      <a class="brand" href="/" aria-label="MTG Auto Deck home">
        <img src="/favicon.png" alt="" width="32" height="32" />
        <span>MTG Auto Deck</span>
      </a>
      <nav class="nav-actions" aria-label="Account links">
        <a class="text-link" href={signInUrl}>Log in</a>
        <a class="button button-secondary" href={signUpUrl}>Try it for free</a>
      </nav>
    </header>

    <main>
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-background" aria-hidden="true"></div>
        <div class="hero-overlay" aria-hidden="true"></div>
        <div class="hero-content">
          <p class="eyebrow">AI goldfishing for Magic decks</p>
          <h1 id="hero-title">MTG Auto Deck</h1>
          <p class="hero-copy">
            Automatically simulate your deck through real turns
          </p>
          <div class="hero-actions" aria-label="Primary calls to action">
            <a class="button button-primary" href={signUpUrl}>Try it for free</a
            >
            <a class="button button-ghost" href="#pricing">See pricing</a>
          </div>
        </div>
      </section>

      <section class="section feature-section" aria-labelledby="features-title">
        <div class="section-header">
          <p class="eyebrow">Not just basic analysis</p>
          <h2 id="features-title">See how the deck actually plays.</h2>
          <p>
            MTG Auto Deck runs through the turns for you, logging the important
            actions so you can see where your deck works, and where it doesn't.
          </p>
        </div>

        <div class="feature-grid">
          {
            features.map((feature) => (
              <article class="feature">
                <span class="feature-marker" aria-hidden="true" />
                <h3>{feature.label}</h3>
                <p>{feature.description}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section
        class="section pricing-section"
        id="pricing"
        aria-labelledby="pricing-title"
      >
        <div class="section-header">
          <p class="eyebrow">Pricing</p>
          <h2 id="pricing-title">Try for free</h2>
          <p>spend less time goldfishing and more time building your deck.</p>
        </div>

        <div class="pricing-grid">
          {
            plans.map((plan) => (
              <article class="plan">
                <h3>{plan.name}</h3>
                <p class="plan-description">{plan.description}</p>
                <p class="plan-price">
                  <span>{plan.price}</span>
                  <small>{plan.cadence}</small>
                </p>
                <ul>
                  {plan.features.map((feature) => (
                    <li>{feature}</li>
                  ))}
                </ul>
                <a class="button button-secondary" href={signUpUrl}>
                  {plan.cta}
                </a>
              </article>
            ))
          }
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    --bg: #0b1020;
    --bg-deep: #05070d;
    --surface: #101827;
    --surface-raised: #151f31;
    --text: #f8fafc;
    --muted: #aeb8c7;
    --subtle: #7d8ca1;
    --border: rgba(226, 232, 240, 0.14);
    --border-strong: rgba(125, 211, 252, 0.38);
    --accent: #38bdf8;
    --accent-strong: #7dd3fc;
    --accent-dark: #0f3d5a;
    --green: #6ee7b7;
    --amber: #f8c471;
    --shadow: rgba(0, 0, 0, 0.45);
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg-deep);
    scroll-behavior: smooth;
  }

  body {
    min-width: 320px;
    margin: 0;
    background: var(--bg-deep);
    color: var(--text);
    font-family: inherit;
    line-height: 1.5;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  body::selection {
    background: rgba(56, 189, 248, 0.3);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .site-header {
    position: absolute;
    inset: 0 0 auto;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 1rem 0;
  }

  .brand,
  .nav-actions,
  .hero-actions {
    display: flex;
    align-items: center;
  }

  .brand {
    gap: 0.7rem;
    min-width: 0;
    font-weight: 800;
    letter-spacing: 0;
  }

  .brand img {
    flex: 0 0 auto;
  }

  .brand span {
    overflow-wrap: anywhere;
  }

  .nav-actions {
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .text-link {
    color: var(--muted);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .text-link:hover {
    color: var(--text);
  }

  .button {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    font-weight: 800;
    line-height: 1;
    text-align: center;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease,
      color 160ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button-primary {
    background: var(--accent-strong);
    color: #07111d;
    box-shadow: 0 14px 34px rgba(56, 189, 248, 0.22);
  }

  .button-primary:hover {
    background: #bae6fd;
  }

  .button-secondary {
    border-color: rgba(125, 211, 252, 0.32);
    background: rgba(15, 61, 90, 0.7);
    color: var(--text);
  }

  .button-secondary:hover {
    border-color: var(--accent-strong);
    background: rgba(15, 61, 90, 0.95);
  }

  .button-ghost {
    border-color: var(--border);
    background: rgba(5, 7, 13, 0.54);
    color: var(--text);
  }

  .button-ghost:hover {
    border-color: var(--border-strong);
    background: rgba(11, 16, 32, 0.82);
  }

  .hero {
    position: relative;
    isolation: isolate;
    display: flex;
    min-height: 78svh;
    align-items: center;
    overflow: hidden;
    padding: 7rem 1rem 5.5rem;
    border-bottom: 1px solid var(--border);
  }

  .hero-background,
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: -2;
  }

  .hero-background {
    background-image: url("/simulation-screenshot.png");
    background-position: center top;
    background-size: cover;
    opacity: 0.5;
    filter: saturate(0.9);
  }

  .hero-overlay {
    z-index: -1;
    background:
      linear-gradient(
        90deg,
        rgba(5, 7, 13, 0.96) 0%,
        rgba(5, 7, 13, 0.88) 44%,
        rgba(5, 7, 13, 0.62) 100%
      ),
      linear-gradient(
        0deg,
        rgba(5, 7, 13, 0.92) 0%,
        rgba(5, 7, 13, 0.22) 42%,
        rgba(5, 7, 13, 0.76) 100%
      );
  }

  .hero-content,
  .section {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
  }

  .hero-content {
    padding-top: 2rem;
  }

  .eyebrow {
    margin: 0 0 0.85rem;
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: break-word;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    letter-spacing: 0;
    line-height: 1.02;
  }

  h1 {
    max-width: 760px;
    font-size: clamp(3.6rem, 9vw, 6.8rem);
  }

  h2 {
    max-width: 780px;
    font-size: clamp(2.2rem, 5vw, 4.4rem);
  }

  h3 {
    font-size: 1.18rem;
  }

  .hero-copy {
    max-width: 640px;
    margin: 1.35rem 0 0;
    color: #d8e4f0;
    font-size: clamp(1.12rem, 2vw, 1.35rem);
  }

  .hero-actions {
    gap: 0.85rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .section {
    padding: 5.5rem 0;
  }

  .section-header {
    max-width: 780px;
  }

  .section-header p:not(.eyebrow) {
    margin: 1rem 0 0;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .feature-section {
    background: var(--bg-deep);
  }

  .feature-grid,
  .pricing-grid {
    display: grid;
    gap: 1rem;
    margin-top: 2.2rem;
  }

  .feature-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .feature {
    min-height: 16rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background: var(--surface);
    padding: 1.25rem;
  }

  .feature-marker {
    display: block;
    width: 2.35rem;
    height: 0.28rem;
    margin-bottom: 2.7rem;
    border-radius: 999px;
    background: var(--accent);
  }

  .feature:nth-child(2) .feature-marker {
    background: var(--green);
  }

  .feature:nth-child(3) .feature-marker {
    background: var(--amber);
  }

  .feature p,
  .plan-description,
  .plan li {
    color: var(--muted);
  }

  .feature p {
    margin: 0.85rem 0 0;
  }

  .pricing-section {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .pricing-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: stretch;
  }

  .plan {
    position: relative;
    display: flex;
    min-height: 31rem;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background: var(--surface);
    padding: 1.35rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12);
  }

  .plan-description {
    min-height: 3rem;
    margin: 0.85rem 0 1.15rem;
  }

  .plan-price {
    display: flex;
    align-items: baseline;
    gap: 0.28rem;
    margin: 0;
  }

  .plan-price span {
    color: var(--text);
    font-size: 3rem;
    font-weight: 900;
    line-height: 1;
  }

  .plan-price small {
    color: var(--subtle);
    font-size: 1rem;
    font-weight: 800;
  }

  .plan ul {
    display: grid;
    gap: 0.85rem;
    margin: 1.65rem 0 2rem;
    padding: 0;
    list-style: none;
  }

  .plan li {
    display: flex;
    gap: 0.65rem;
  }

  .plan li::before {
    flex: 0 0 auto;
    width: 0.55rem;
    height: 0.55rem;
    margin-top: 0.47rem;
    border-radius: 50%;
    background: var(--accent);
    content: "";
  }

  .plan .button {
    margin-top: auto;
  }

  @media (max-width: 860px) {
    .feature-grid,
    .pricing-grid {
      grid-template-columns: 1fr;
    }

    .feature,
    .plan {
      min-height: auto;
    }
  }

  @media (max-width: 620px) {
    .site-header {
      align-items: flex-start;
    }

    .brand span {
      max-width: 8.5rem;
      line-height: 1.1;
    }

    .nav-actions {
      gap: 0.55rem;
    }

    .text-link {
      min-height: 2.35rem;
      display: inline-flex;
      align-items: center;
    }

    .button {
      width: 100%;
    }

    .nav-actions .button {
      width: auto;
      padding-inline: 0.8rem;
    }

    .hero {
      min-height: 82svh;
      padding-top: 8rem;
      padding-bottom: 4rem;
    }

    .hero-content,
    .section {
      width: min(100% - 28px, 1120px);
    }

    .hero-overlay {
      background:
        linear-gradient(
          90deg,
          rgba(5, 7, 13, 0.98) 0%,
          rgba(5, 7, 13, 0.88) 100%
        ),
        linear-gradient(
          0deg,
          rgba(5, 7, 13, 0.9) 0%,
          rgba(5, 7, 13, 0.5) 44%,
          rgba(5, 7, 13, 0.8) 100%
        );
    }

    .hero-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .section {
      padding: 4rem 0;
    }

    .plan-price span {
      font-size: 2.55rem;
    }
  }
</style>
