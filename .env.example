# postgres database connection info
PGHOST=localhost
PGPORT=5432
PGDATABASE=
PGUSER=postgres
PGPASSWORD=

# LLM simulation runs
# LLM_PROVIDER must be openai, openrouter, or llamacpp
LLM_PROVIDER=openai
# Maximum generated tokens per LLM call, including reasoning tokens
LLM_MAX_OUTPUT_TOKENS=100000

# OpenAI settings (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
OPENAI_REASONING_EFFORT=medium

# OpenRouter settings (used when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5-nano
OPENROUTER_MODEL_PROVIDER=
OPENROUTER_REASONING_EFFORT=medium
OPENROUTER_STOP_WHEN_STEP_COUNT=250

# llama.cpp settings (used when LLM_PROVIDER=llamacpp)
LLAMACPP_BASE_URL=http://127.0.0.1:8080/v1
LLAMACPP_API_KEY= #optional
LLAMACPP_STOP_WHEN_STEP_COUNT=250

# OpenAI hosted MCP public URLs (used when LLM_PROVIDER=openai)
OPENING_HAND_MCP_PUBLIC_URL=
TURN_SIMULATION_MCP_PUBLIC_URL=
