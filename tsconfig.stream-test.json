{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "types": ["node"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "strict": true,
    "outDir": "./node_modules/.tmp/stream-test",
    "rootDir": "."
  },
  "include": [
    "src/lib/deck-types.ts",
    "src/lib/simulation-debug-chunks.ts",
    "src/lib/simulation-final-output.ts",
    "mtg-auto-goldfish-server/simulation-run-text.ts",
    "src/lib/simulation-result-chunks.ts",
    "src/lib/simulation-result-tool-labels.ts",
    "src/lib/simulation-results-stream.ts",
    "tests/simulation-results-stream.test.ts"
  ]
}
