# postgres database connection info
PGHOST=localhost
PGPORT=5432
PGDATABASE=
PGUSER=postgres
PGPASSWORD=

# App authentication
BETTER_AUTH_SECRET= # <generate-a-long-random-secret>
BETTER_AUTH_URL=http://127.0.0.1:3001
APP_PUBLIC_URL=http://127.0.0.1:5173

# Auth email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# LLM simulation runs
# Maximum generated tokens per LLM call, including reasoning tokens
LLM_MAX_OUTPUT_TOKENS=100000
# Maximum LLM calls that may actively stream at the same time
LLM_RUN_QUEUE_MAX_CONCURRENT_RUNS=50
# Maximum LLM calls that may actively stream for one deck owner at the same time
LLM_RUN_QUEUE_MAX_CONCURRENT_RUNS_PER_USER=5

# OpenAI settings
OPENAI_API_KEY=

# OpenRouter settings
OPENROUTER_API_KEY=
OPENROUTER_STOP_WHEN_STEP_COUNT=250

# llama.cpp settings
LLAMACPP_BASE_URL=http://127.0.0.1:8080/v1
LLAMACPP_API_KEY= #optional
LLAMACPP_STOP_WHEN_STEP_COUNT=250

# OpenAI hosted MCP public URLs
OPENING_HAND_MCP_PUBLIC_URL=
TURN_SIMULATION_MCP_PUBLIC_URL=

# Test-only standalone simulation MCP server. Do not expose publicly unless you
# are intentionally testing this endpoint.
SIMULATION_MCP_SERVER_ENABLED=false
